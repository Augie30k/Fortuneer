# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Force LF for these text-based formats regardless of platform
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.html text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.sh text eol=lf
.env.example text eol=lf

# Windows-specific scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Lockfiles: never manually edit, always LF, exclude from diffs/exports
package-lock.json text eol=lf -diff linguist-generated
next-env.d.ts linguist-generated

# SVGs are XML text — keep them diffable
*.svg text eol=lf

# Binary assets: no text conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.pdf binary
